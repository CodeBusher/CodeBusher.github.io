---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import { formatNoteDate } from '@/lib/format';
import { decodeTopicPathParam, noteDetailPath, parseNoteId, topicBreadcrumbs } from '@/lib/note-taxonomy';
import { getPublishedNotes, noteTopicListingUrl, topicOf } from '@/lib/notes';

export async function getStaticPaths() {
  const notes = await getPublishedNotes();
  return notes.map((note) => {
    const { topicPath, slug } = parseNoteId(note.id);
    return { params: { topic: topicPath, slug }, props: { id: note.id } };
  });
}

const { id } = Astro.props;
const entry = await getEntry('notes', id);

if (!entry || entry.data.draft) {
  return Astro.redirect('/404/');
}

const parsed = parseNoteId(entry.id);
const paramTopic = decodeTopicPathParam(
  Array.isArray(Astro.params.topic) ? Astro.params.topic.join('/') : Astro.params.topic,
);
const paramSlug = decodeURIComponent(Astro.params.slug ?? '');

if (paramTopic !== parsed.topicPath || paramSlug !== parsed.slug) {
  return Astro.redirect('/404/');
}

const { Content } = await render(entry);
const crumbs = [...topicBreadcrumbs(parsed.topicPath), { label: entry.data.title, href: noteDetailPath(parsed.topicPath, parsed.slug) }];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="prose">
    <nav class="crumbs sans" aria-label="Breadcrumb">
      {
        crumbs.map((c, i) => (
          <span class="crumb-part">
            {i > 0 && <span class="sep"> / </span>}
            {i < crumbs.length - 1 ? (
              <a href={c.href}>{c.label}</a>
            ) : (
              <span aria-current="page">{c.label}</span>
            )}
          </span>
        ))
      }
    </nav>
    <header class="post-header">
      <h1>{entry.data.title}</h1>
      <p class="byline sans">
        <time datetime={formatNoteDate(entry.data.pubDate)}>{formatNoteDate(entry.data.pubDate)}</time>
        <span> · </span>
        <a href={noteTopicListingUrl(entry)}>{topicOf(entry)}</a>
        {
          entry.data.updatedDate && (
            <>
              <span> · </span>
              <span>Updated {formatNoteDate(entry.data.updatedDate)}</span>
            </>
          )
        }
      </p>
    </header>
    <Content />
  </article>
</BaseLayout>

<style>
  .crumbs {
    font-size: 0.8125rem;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .crumbs a {
    color: var(--muted);
  }

  .crumbs a:hover {
    color: var(--ink);
  }

  .sep {
    color: var(--rule);
  }

  .post-header h1 {
    font-size: clamp(1.65rem, 3.5vw, 2rem);
    font-weight: 600;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  .byline {
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 0 0 2rem;
  }

</style>
