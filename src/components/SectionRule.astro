<div class="divider" aria-hidden="true"><span></span></div>

<style>
  .divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 2.25rem 0;
    color: var(--rule);
  }

  .divider::before,
  .divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--rule);
  }

  .divider span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--dot);
    flex-shrink: 0;
  }
</style>
